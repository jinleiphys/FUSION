diff --git a/src/Utilities/FloatingPointExceptions.hpp b/src/Utilities/FloatingPointExceptions.hpp
index cddc37d..b4501ce 100644
--- a/src/Utilities/FloatingPointExceptions.hpp
+++ b/src/Utilities/FloatingPointExceptions.hpp
@@ -12,11 +12,17 @@
 // find out whether we are using a GNU compiler, use information given at
 // http://nadeausoftware.com/articles/2012/10/c_c_tip_how_detect_compiler_name_and_version_using_compiler_predefined_macros
 
-#if (defined(__GNUC__) || defined(__GNUG__))
+// FUSION portability: feenableexcept/fedisableexcept are glibc extensions, not
+// compiler features. Apple clang defines __GNUC__ (it masquerades as GCC 4.2),
+// so the original "is a GNU compiler" test wrongly enabled FPE trapping on
+// macOS and failed to link. The correct test is for glibc. FPE trapping is a
+// debugging aid (raises SIGFPE on NaN/Inf), not physics, so on non-glibc
+// platforms Enable()/Disable() become no-ops and the computed results are
+// unchanged.
+#if (defined(__GNUC__) || defined(__GNUG__)) && defined(__GLIBC__)
 #define SKYNET_ENABLE_FPE
 #else
 #undef SKYNET_ENABLE_FPE
-#warning "Floating point exceptions are only supported with GNU"
 #endif
 
 #ifdef SKYNET_ENABLE_FPE
