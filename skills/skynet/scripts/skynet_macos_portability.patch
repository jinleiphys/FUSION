diff --git a/CMakeLists.txt b/CMakeLists.txt
index 475e6f3..a2588e8 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -109,6 +109,11 @@ add_library(SkyNet SHARED
   ${SKYNET_LIBS}
 )
 
+# FUSION portability: macOS does not permit undefined symbols in a dylib
+# (Linux resolves them lazily at load time), so the shared library must link
+# its external dependencies (HDF5, GSL, Boost, LAPACK) explicitly.
+target_link_libraries(SkyNet ${SKYNET_EXTERNAL_LIBS})
+
 # create SWIG Python bindings
 if(USE_SWIG)
   SET_SOURCE_FILES_PROPERTIES("src/SkyNet.i" PROPERTIES CPLUSPLUS ON)
diff --git a/CMakeLists_Requirements.txt b/CMakeLists_Requirements.txt
index fa66530..23bf5e7 100644
--- a/CMakeLists_Requirements.txt
+++ b/CMakeLists_Requirements.txt
@@ -10,7 +10,11 @@ find_package(GSL REQUIRED)
 set(SKYNET_EXTERNAL_LIBS "${SKYNET_EXTERNAL_LIBS};${GSL_LIBRARIES}")
 include_directories(${GSL_INCLUDES})
 
-find_package(Boost REQUIRED system filesystem serialization)
+# FUSION portability: Boost.System is header-only since Boost 1.69 and modern
+# Boost CMake configs (>= 1.85) no longer ship a linkable boost_system target,
+# so requesting it as a component fails to configure. Boost.Filesystem no longer
+# needs it linked. Drop it; filesystem and serialization are still required.
+find_package(Boost REQUIRED filesystem serialization)
 set(SKYNET_EXTERNAL_LIBS "${SKYNET_EXTERNAL_LIBS};${Boost_LIBRARIES}")
 include_directories(${Boost_INCLUDE_DIRS})
 
